# BE environment variables (development placeholders)
# Copy this file to be/.env and update values. Do NOT commit real secrets.

NODE_ENV=development

# Postgres connection
PGHOST=localhost
PGPORT=5432
PGUSER=sivi_user
PGPASSWORD=sivi_pass
PGDATABASE=sivi_db

# JWT configuration
JWT_SECRET=devsecret
JWT_EXPIRATION_MINUTES=30

# Optional DB encryption key (used by BE for encrypting sensitive fields)
DB_ENCRYPTION_KEY=dev_encryption_key_placeholder

# Additional (optional)
#LOG_LEVEL=debug
